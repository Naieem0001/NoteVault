# Copy this file to `.env.local` and fill in values. Do NOT commit real keys.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Example: For server-side/service usage keep a separate secret named SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key